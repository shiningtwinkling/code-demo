@prefix : <http://example.org/eu-ai-act#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

#################################################################
# Ontology Metadata
#################################################################

:EU_AI_Act_Ontology rdf:type owl:Ontology ;
    dcterms:title "EU AI Act Ontology" ;
    dcterms:description "Ontology modelling AI systems, actors, obligations and governance structures under the EU AI Act." ;
    dcterms:source "Regulation (EU) 2024/1689 (Artificial Intelligence Act)" ;
    dcterms:created "2026-03-06"^^xsd:date .

#################################################################
# Annotation Property
#################################################################

:aiActArticle rdf:type owl:AnnotationProperty ;
    rdfs:label "AI Act Article Reference" .

#################################################################
# Core Classes
#################################################################

:AI_System rdf:type owl:Class ;
    rdfs:label "AI System" ;
    rdfs:comment "Machine-based system generating outputs such as predictions, recommendations or decisions." ;
    :aiActArticle "Art.3" .

:Actor rdf:type owl:Class ;
    rdfs:label "Actor" ;
    rdfs:comment "Entity involved in the development, distribution, deployment, or governance of AI systems." .

:Obligation rdf:type owl:Class ;
    rdfs:label "Regulatory Obligation" ;
    rdfs:comment "Requirement imposed by the EU AI Act on actors or AI systems." .

:Governance rdf:type owl:Class ;
    rdfs:label "Governance Authority" ;
    rdfs:comment "Institution responsible for oversight and enforcement of the AI Act." .

#################################################################
# AI System Categories
#################################################################

:Prohibited_AI_Practice rdf:type owl:Class ;
    rdfs:subClassOf :AI_System ;
    rdfs:label "Prohibited AI Practice" ;
    :aiActArticle "Art.5" .

:High_Risk_AI_System rdf:type owl:Class ;
    rdfs:subClassOf :AI_System ;
    rdfs:label "High Risk AI System" ;
    :aiActArticle "Art.6" .

:Certain_AI_System rdf:type owl:Class ;
    rdfs:subClassOf :AI_System ;
    rdfs:label "Certain AI System" ;
    rdfs:comment "AI systems subject to transparency obligations." ;
    :aiActArticle "Art.50" .

:General_Purpose_AI_Model rdf:type owl:Class ;
    rdfs:subClassOf :AI_System ;
    rdfs:label "General Purpose AI Model" ;
    :aiActArticle "Art.52" .

#################################################################
# Actor Classes
#################################################################

:Provider rdf:type owl:Class ;
    rdfs:subClassOf :Actor ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :developsAI ;
          owl:someValuesFrom :AI_System
        ] ;
    rdfs:label "Provider" ;
    :aiActArticle "Art.3(3)" .

:Deployer rdf:type owl:Class ;
    rdfs:subClassOf :Actor ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :deploysAI ;
          owl:someValuesFrom :AI_System
        ] ;
    rdfs:label "Deployer" ;
    :aiActArticle "Art.3(4)" .

:Distributor rdf:type owl:Class ;
    rdfs:subClassOf :Actor ;
    rdfs:label "Distributor" ;
    :aiActArticle "Art.3(7)" .

:Importer rdf:type owl:Class ;
    rdfs:subClassOf :Actor ;
    rdfs:label "Importer" ;
    :aiActArticle "Art.3(6)" .

:Authority rdf:type owl:Class ;
    rdfs:subClassOf :Actor , :Governance ;
    rdfs:label "Authority" .

#################################################################
# Governance Subclasses
#################################################################

:AI_Office rdf:type owl:Class ;
    rdfs:subClassOf :Authority ;
    rdfs:label "AI Office" ;
    :aiActArticle "Art.64" .

:European_AI_Board rdf:type owl:Class ;
    rdfs:subClassOf :Authority ;
    rdfs:label "European Artificial Intelligence Board" ;
    :aiActArticle "Art.65" .

:Market_Surveillance_Authority rdf:type owl:Class ;
    rdfs:subClassOf :Authority ;
    rdfs:label "Market Surveillance Authority" .

:National_Competent_Authority rdf:type owl:Class ;
    rdfs:subClassOf :Authority ;
    rdfs:label "National Competent Authority" .

:Notified_Body rdf:type owl:Class ;
    rdfs:subClassOf :Authority ;
    rdfs:label "Notified Body" .

#################################################################
# Obligation Subclasses
#################################################################

:Risk_Management_Obligation rdf:type owl:Class ;
    rdfs:subClassOf :Obligation ;
    rdfs:label "Risk Management Obligation" ;
    :aiActArticle "Art.9" .

:Data_Governance_Obligation rdf:type owl:Class ;
    rdfs:subClassOf :Obligation ;
    rdfs:label "Data Governance Obligation" ;
    :aiActArticle "Art.10" .

:Technical_Documentation_Obligation rdf:type owl:Class ;
    rdfs:subClassOf :Obligation ;
    rdfs:label "Technical Documentation Obligation" ;
    :aiActArticle "Art.11" .

:Transparency_Obligation rdf:type owl:Class ;
    rdfs:subClassOf :Obligation ;
    rdfs:label "Transparency Obligation" ;
    :aiActArticle "Art.13" .

:Human_Oversight_Obligation rdf:type owl:Class ;
    rdfs:subClassOf :Obligation ;
    rdfs:label "Human Oversight Obligation" ;
    :aiActArticle "Art.14" .

:Accuracy_Robustness_Cybersecurity_Obligation rdf:type owl:Class ;
    rdfs:subClassOf :Obligation ;
    rdfs:label "Accuracy Robustness Cybersecurity Obligation" ;
    :aiActArticle "Art.15" .

:Conformity_Assessment_Obligation rdf:type owl:Class ;
    rdfs:subClassOf :Obligation ;
    rdfs:label "Conformity Assessment Obligation" ;
    :aiActArticle "Art.43" .

:Post_Market_Monitoring_Obligation rdf:type owl:Class ;
    rdfs:subClassOf :Obligation ;
    rdfs:label "Post Market Monitoring Obligation" .

:AI_Literacy_Obligation rdf:type owl:Class ;
    rdfs:subClassOf :Obligation ;
    rdfs:label "AI Literacy Obligation" ;
    :aiActArticle "Art.4" .

#################################################################
# Object Properties
#################################################################

:developsAI rdf:type owl:ObjectProperty ;
    rdfs:domain :Actor ;
    rdfs:range :AI_System ;
    rdfs:label "develops AI system" .

:placesOnMarket rdf:type owl:ObjectProperty ;
    rdfs:domain :Actor ;
    rdfs:range :AI_System ;
    rdfs:label "places AI system on market" .

:deploysAI rdf:type owl:ObjectProperty ;
    rdfs:domain :Actor ;
    rdfs:range :AI_System ;
    rdfs:label "deploys AI system" .

:importsAI rdf:type owl:ObjectProperty ;
    rdfs:domain :Importer ;
    rdfs:range :AI_System ;
    rdfs:label "imports AI system" .

:distributesAI rdf:type owl:ObjectProperty ;
    rdfs:domain :Distributor ;
    rdfs:range :AI_System ;
    rdfs:label "distributes AI system" .

:subjectToObligation rdf:type owl:ObjectProperty ;
    rdfs:domain :Actor ;
    rdfs:range :Obligation ;
    rdfs:label "subject to obligation" .

:appliesToSystem rdf:type owl:ObjectProperty ;
    rdfs:domain :Obligation ;
    rdfs:range :AI_System ;
    rdfs:label "applies to system" .

:supervisesActor rdf:type owl:ObjectProperty ;
    rdfs:domain :Authority ;
    rdfs:range :Actor ;
    rdfs:label "supervises actor" .

:regulatesSystem rdf:type owl:ObjectProperty ;
    rdfs:domain :Authority ;
    rdfs:range :AI_System ;
    rdfs:label "regulates system" .

:enforcesObligation rdf:type owl:ObjectProperty ;
    rdfs:domain :Authority ;
    rdfs:range :Obligation ;
    rdfs:label "enforces obligation" .

:assessesConformityOf rdf:type owl:ObjectProperty ;
    rdfs:domain :Notified_Body ;
    rdfs:range :AI_System ;
    rdfs:label "assesses conformity of AI system" .

:reportsToAuthority rdf:type owl:ObjectProperty ;
    rdfs:domain :Actor ;
    rdfs:range :Authority ;
    rdfs:label "reports to authority" .

#################################################################
# Example Logical Restriction
#################################################################

:High_Risk_AI_System
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :appliesToSystem ;
          owl:someValuesFrom :Risk_Management_Obligation
        ] .


#################################################################
# Example AI Systems
#################################################################

:City_Face_Recognition_System rdf:type :High_Risk_AI_System ;
    rdfs:label "City Facial Recognition System" .

:Autonomous_Driving_AI rdf:type :High_Risk_AI_System ;
    rdfs:label "Autonomous Driving AI System" .

:Biometric_Identification_System rdf:type :High_Risk_AI_System ;
    rdfs:label "Biometric Identification System" .

:Emotion_Detection_System rdf:type :Certain_AI_System ;
    rdfs:label "Emotion Detection AI System" .

:Credit_Scoring_AI rdf:type :High_Risk_AI_System ;
    rdfs:label "AI Credit Scoring System" .

:Content_Generation_Model rdf:type :General_Purpose_AI_Model ;
    rdfs:label "AI Content Generation Foundation Model" .


:Foundation_LLM_Model rdf:type :General_Purpose_AI_Model ;
    rdfs:label "Foundation Large Language Model" .

:Customer_Service_Chatbot rdf:type :Certain_AI_System ;
    rdfs:label "Customer Service AI Chatbot" .



#################################################################
# Example Actors
#################################################################

:VisionTech_Ltd rdf:type :Provider ;
    rdfs:label "VisionTech Ltd" ;
    :developsAI :City_Face_Recognition_System ;
    :subjectToObligation :Risk_Management_Requirement ,
                         :Transparency_Requirement .

:EuroAI_Solutions rdf:type :Provider ;
    rdfs:label "EuroAI Solutions" ;
    :developsAI :Customer_Service_Chatbot ;
    :placesOnMarket :Customer_Service_Chatbot .

:RetailBank_Group rdf:type :Deployer ;
    rdfs:label "RetailBank Group" ;
    :deploysAI :Customer_Service_Chatbot ;
    :subjectToObligation :Transparency_Requirement .

:GlobalTech_Imports rdf:type :Importer ;
    rdfs:label "GlobalTech Imports" ;
    :importsAI :Foundation_LLM_Model .

:AI_Supply_Distributor rdf:type :Distributor ;
    rdfs:label "AI Supply Distributor" ;
    :distributesAI :City_Face_Recognition_System .

:AutoDrive_Tech rdf:type :Provider ;
    rdfs:label "AutoDrive Technologies" ;
    :developsAI :Autonomous_Driving_AI ;
    :subjectToObligation :Risk_Management_Requirement ,
                         :Technical_Documentation_Requirement ,
                         :Human_Oversight_Requirement ;
    :reportsToAuthority :German_Market_Surveillance_Authority .

:BioSecure_AI rdf:type :Provider ;
    rdfs:label "BioSecure AI Ltd" ;
    :developsAI :Biometric_Identification_System ;
    :subjectToObligation :Risk_Management_Requirement ,
                         :Conformity_Assessment_Requirement .

:CreativeGen_Labs rdf:type :Provider ;
    rdfs:label "CreativeGen Labs" ;
    :developsAI :Content_Generation_Model ;
    :subjectToObligation :Transparency_Requirement .

:SmartCity_Authority rdf:type :Deployer ;
    rdfs:label "SmartCity Urban Authority" ;
    :deploysAI :Biometric_Identification_System ;
    :subjectToObligation :Human_Oversight_Requirement ,
                         :Transparency_Requirement .

:AutoFleet_Operator rdf:type :Deployer ;
    rdfs:label "AutoFleet Mobility Operator" ;
    :deploysAI :Autonomous_Driving_AI ;
    :subjectToObligation :Post_Market_Monitoring_Requirement .

:FinanceCorp_Bank rdf:type :Deployer ;
    rdfs:label "FinanceCorp Bank" ;
    :deploysAI :Credit_Scoring_AI ;
    :subjectToObligation :Transparency_Requirement ,
                         :Human_Oversight_Requirement .

:Global_AI_Imports rdf:type :Importer ;
    rdfs:label "Global AI Imports Ltd" ;
    :importsAI :Content_Generation_Model ;
    :reportsToAuthority :German_Market_Surveillance_Authority .

:EuroTech_Distribution rdf:type :Distributor ;
    rdfs:label "EuroTech Distribution Network" ;
    :distributesAI :Biometric_Identification_System .

:AI_Industry_Supply rdf:type :Distributor ;
    rdfs:label "AI Industry Supply Chain Ltd" ;
    :distributesAI :Autonomous_Driving_AI .

#################################################################
# Governance Authorities
#################################################################

:EU_AI_Office_Instance rdf:type :AI_Office ;
    rdfs:label "European AI Office" ;
    :regulatesSystem :Foundation_LLM_Model .

:EU_AI_Board_Instance rdf:type :European_AI_Board ;
    rdfs:label "European Artificial Intelligence Board" ;
    :supervisesActor :VisionTech_Ltd ,
                     :EuroAI_Solutions .

:German_Market_Surveillance_Authority rdf:type :Market_Surveillance_Authority ;
    rdfs:label "German Market Surveillance Authority" ;
    :supervisesActor :RetailBank_Group ;
    :monitorsComplianceOf :RetailBank_Group .

:EU_Notified_Body_001 rdf:type :Notified_Body ;
    rdfs:label "EU Notified Body 001" ;
    :assessesConformityOf :City_Face_Recognition_System .

:French_Market_Surveillance_Authority rdf:type :Market_Surveillance_Authority ;
    rdfs:label "French Market Surveillance Authority" ;
    :supervisesActor :AutoDrive_Tech ,
                     :AutoFleet_Operator ;
    :enforcesObligation :Risk_Management_Requirement .

:Italian_National_AI_Authority rdf:type :National_Competent_Authority ;
    rdfs:label "Italian National AI Authority" ;
    :supervisesActor :FinanceCorp_Bank ,
                     :BioSecure_AI ;
    :enforcesObligation :Transparency_Requirement ,
                        :Human_Oversight_Requirement .

#################################################################
# Example Obligations
#################################################################

:Risk_Management_Requirement rdf:type :Risk_Management_Obligation ;
    rdfs:label "Risk Management Requirement" ;
    :appliesToSystem :High_Risk_AI_System .

:Transparency_Requirement rdf:type :Transparency_Obligation ;
    rdfs:label "Transparency Requirement" ;
    :appliesToSystem :Certain_AI_System .

:Human_Oversight_Requirement rdf:type :Human_Oversight_Obligation ;
    rdfs:label "Human Oversight Requirement" ;
    :appliesToSystem :High_Risk_AI_System .

:Conformity_Assessment_Requirement rdf:type :Conformity_Assessment_Obligation ;
    rdfs:label "Conformity Assessment Requirement" ;
    :appliesToSystem :High_Risk_AI_System .

:Technical_Documentation_Requirement rdf:type :Technical_Documentation_Obligation ;
    rdfs:label "Technical Documentation Requirement" ;
    :appliesToSystem :High_Risk_AI_System .

:Post_Market_Monitoring_Requirement rdf:type :Post_Market_Monitoring_Obligation ;
    rdfs:label "Post Market Monitoring Requirement" ;
    :appliesToSystem :High_Risk_AI_System .

:AI_Literacy_Requirement rdf:type :AI_Literacy_Obligation ;
    rdfs:label "AI Literacy Requirement" .

#################################################################
# Governance Enforcement Relationships
#################################################################

:German_Market_Surveillance_Authority
    :enforcesObligation :Transparency_Requirement .

:EU_AI_Office_Instance
    :enforcesObligation :Risk_Management_Requirement .

:EU_Notified_Body_001
    :enforcesObligation :Conformity_Assessment_Requirement .

:EU_AI_Board_Instance
    :supervisesActor :AutoDrive_Tech ,
                     :BioSecure_AI ,
                     :CreativeGen_Labs .

:EU_AI_Office_Instance
    :regulatesSystem :Content_Generation_Model ,
                     :Foundation_LLM_Model .

:French_Market_Surveillance_Authority
    :regulatesSystem :Autonomous_Driving_AI .

#################################################################
# Reporting Relationship
#################################################################

:VisionTech_Ltd
    :reportsToAuthority :German_Market_Surveillance_Authority .