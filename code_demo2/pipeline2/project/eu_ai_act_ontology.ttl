@prefix euaia: <http://example.org/eu-ai-act#> .
@prefix ex: <http://example.org/eu-ai-act/instance#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

euaia:Accuracy_Robustness_Cybersecurity_Obligation a owl:Class ;
    rdfs:label "Accuracy/Robustness/Cybersecurity Obligation"@en ;
    euaia:articleReference "Article 15"^^xsd:string ;
    rdfs:comment "Ensure required levels of accuracy, robustness and cybersecurity."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:Advisory_Forum a owl:Class ;
    rdfs:label "Advisory Forum"@en ;
    euaia:articleReference "Article 67"^^xsd:string ;
    rdfs:comment "Multi-stakeholder advisory forum to support implementation."@en ;
    rdfs:subClassOf euaia:Governance .

euaia:Human_Oversight_Obligation a owl:Class ;
    rdfs:label "Human Oversight Obligation"@en ;
    euaia:articleReference "Article 14"^^xsd:string ;
    rdfs:comment "Ensure effective human oversight measures during operation."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:Record_Keeping_Obligation a owl:Class ;
    rdfs:label "Record-Keeping Obligation"@en ;
    euaia:articleReference "Article 12"^^xsd:string ;
    rdfs:comment "Enable logging and traceability of high-risk AI operations."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:Scientific_Panel a owl:Class ;
    rdfs:label "Scientific Panel"@en ;
    euaia:articleReference "Article 68"^^xsd:string ;
    rdfs:comment "Independent scientific experts supporting governance tasks."@en ;
    rdfs:subClassOf euaia:Governance .

euaia:Technical_Documentation_Obligation a owl:Class ;
    rdfs:label "Technical Documentation Obligation"@en ;
    euaia:articleReference "Article 11"^^xsd:string ;
    rdfs:comment "Draw up technical documentation before placing high-risk AI on market."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:articleReference a owl:AnnotationProperty ;
    rdfs:label "EU AI Act article reference"@en .

euaia:deploys a owl:ObjectProperty ;
    rdfs:label "deploys"@en ;
    euaia:articleReference "Article 26"^^xsd:string ;
    rdfs:comment "Deployer uses an AI system in an operational context."@en ;
    rdfs:domain euaia:Deployer ;
    rdfs:range euaia:AI_System .

euaia:distributes a owl:ObjectProperty ;
    rdfs:label "distributes"@en ;
    euaia:articleReference "Article 24"^^xsd:string ;
    rdfs:comment "Distributor makes an AI system available in the market chain."@en ;
    rdfs:domain euaia:Distributor ;
    rdfs:range euaia:AI_System .

euaia:governs a owl:ObjectProperty ;
    rdfs:label "governs"@en ;
    euaia:articleReference "Articles 64-71"^^xsd:string ;
    rdfs:comment "Governance body oversees or coordinates actor behaviour."@en ;
    rdfs:domain euaia:Governance ;
    rdfs:range euaia:Actor ;
    owl:inverseOf euaia:governed_by .

euaia:imports a owl:ObjectProperty ;
    rdfs:label "imports"@en ;
    euaia:articleReference "Article 23"^^xsd:string ;
    rdfs:comment "Importer introduces an AI system from outside the Union market."@en ;
    rdfs:domain euaia:Importer ;
    rdfs:range euaia:AI_System .

euaia:participates_in_sandbox a owl:ObjectProperty ;
    rdfs:label "participates in sandbox"@en ;
    euaia:articleReference "Articles 57-58"^^xsd:string ;
    rdfs:comment "Actor participates in an AI regulatory sandbox."@en ;
    rdfs:domain euaia:Actor ;
    rdfs:range euaia:AI_Regulatory_Sandbox .

euaia:provides a owl:ObjectProperty ;
    rdfs:label "provides"@en ;
    euaia:articleReference "Articles 16, 53"^^xsd:string ;
    rdfs:comment "Provider places or makes available an AI system or model."@en ;
    rdfs:domain euaia:Provider ;
    rdfs:range euaia:AI_System .

euaia:regulates a owl:ObjectProperty ;
    rdfs:label "regulates"@en ;
    euaia:articleReference "Articles 57-71"^^xsd:string ;
    rdfs:comment "Governance body regulates or supervises a system category or instance."@en ;
    rdfs:domain euaia:Governance ;
    rdfs:range euaia:AI_System ;
    owl:inverseOf euaia:regulated_by .

euaia:subject_to_obligation a owl:ObjectProperty ;
    rdfs:label "subject to obligation"@en ;
    euaia:articleReference "Articles 5-56"^^xsd:string ;
    rdfs:comment "Links an actor or system to an applicable legal obligation."@en ;
    rdfs:domain owl:Thing ;
    rdfs:range euaia:Obligation ;
    owl:inverseOf euaia:obligation_for .

ex:europeanAIBoard a euaia:European_AI_Board ;
    rdfs:label "European AI Board"@en ;
    euaia:governs ex:franceAuthority .

euaia:AI_Office a owl:Class ;
    rdfs:label "AI Office"@en ;
    euaia:articleReference "Article 64"^^xsd:string ;
    rdfs:comment "EU-level office supporting implementation and oversight of GPAI."@en ;
    rdfs:subClassOf euaia:Governance .

euaia:Authority a owl:Class ;
    rdfs:label "Authority"@en ;
    euaia:articleReference "Article 70"^^xsd:string ;
    rdfs:comment "Public authority with supervisory or enforcement functions."@en ;
    rdfs:subClassOf euaia:Actor .

euaia:Authority_Cooperation_Obligation a owl:Class ;
    rdfs:label "Authority Cooperation Obligation"@en ;
    euaia:articleReference "Article 70"^^xsd:string ;
    rdfs:comment "National authorities cooperate, coordinate and support enforcement tasks."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:Certain_AI_System a owl:Class ;
    rdfs:label "Certain AI System"@en ;
    euaia:articleReference "Article 50"^^xsd:string ;
    rdfs:comment "AI systems subject to transparency obligations."@en ;
    rdfs:subClassOf euaia:AI_System .

euaia:Data_Governance_Obligation a owl:Class ;
    rdfs:label "Data Governance Obligation"@en ;
    euaia:articleReference "Article 10"^^xsd:string ;
    rdfs:comment "Ensure quality and governance of training, validation and test data."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:Deployer_Obligation a owl:Class ;
    rdfs:label "Deployer Obligation"@en ;
    euaia:articleReference "Article 26"^^xsd:string ;
    rdfs:comment "Comply with deployer duties for high-risk AI systems."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:Distributor a owl:Class ;
    rdfs:label "Distributor"@en ;
    euaia:articleReference "Article 24"^^xsd:string ;
    rdfs:comment "Entity making an AI system available on the Union market."@en ;
    rdfs:subClassOf euaia:Actor .

euaia:EU_Database a owl:Class ;
    rdfs:label "EU Database"@en ;
    euaia:articleReference "Article 71"^^xsd:string ;
    rdfs:comment "Registration infrastructure for high-risk AI systems."@en ;
    rdfs:subClassOf euaia:Governance .

euaia:European_AI_Board a owl:Class ;
    rdfs:label "European AI Board"@en ;
    euaia:articleReference "Articles 65-66"^^xsd:string ;
    rdfs:comment "Body coordinating national authorities and Commission cooperation."@en ;
    rdfs:subClassOf euaia:Governance .

euaia:Fundamental_Rights_Impact_Assessment_Obligation a owl:Class ;
    rdfs:label "Fundamental Rights Impact Assessment Obligation"@en ;
    euaia:articleReference "Article 27"^^xsd:string ;
    rdfs:comment "Conduct FRIA before specific high-risk deployments."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:GPAI_Provider_Obligation a owl:Class ;
    rdfs:label "GPAI Provider Obligation"@en ;
    euaia:articleReference "Article 53"^^xsd:string ;
    rdfs:comment "Comply with provider duties for general-purpose AI models."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:GPAI_Systemic_Risk_Obligation a owl:Class ;
    rdfs:label "GPAI Systemic Risk Obligation"@en ;
    euaia:articleReference "Article 55"^^xsd:string ;
    rdfs:comment "Additional obligations for GPAI models with systemic risk."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:General_Purpose_AI_Model a owl:Class ;
    rdfs:label "General-Purpose AI Model"@en ;
    euaia:articleReference "Articles 51-55"^^xsd:string ;
    rdfs:comment "General-purpose AI models with specific provider duties."@en ;
    rdfs:subClassOf euaia:AI_System .

euaia:High_Risk_AI_System a owl:Class ;
    rdfs:label "High-Risk AI System"@en ;
    euaia:articleReference "Article 6"^^xsd:string ;
    rdfs:comment "AI systems classified as high-risk requiring strict controls."@en ;
    rdfs:subClassOf euaia:AI_System .

euaia:Importer a owl:Class ;
    rdfs:label "Importer"@en ;
    euaia:articleReference "Article 23"^^xsd:string ;
    rdfs:comment "Entity placing AI systems from third countries on the Union market."@en ;
    rdfs:subClassOf euaia:Actor .

euaia:National_Competent_Authority a owl:Class ;
    rdfs:label "National Competent Authority"@en ;
    euaia:articleReference "Article 70"^^xsd:string ;
    rdfs:comment "Member State authority designated for implementation and supervision."@en ;
    rdfs:subClassOf euaia:Governance .

euaia:Prohibited_AI_Practice a owl:Class ;
    rdfs:label "Prohibited AI Practice"@en ;
    euaia:articleReference "Article 5"^^xsd:string ;
    rdfs:comment "AI practices prohibited due to unacceptable risk."@en ;
    rdfs:subClassOf euaia:AI_System .

euaia:Prohibition_Obligation a owl:Class ;
    rdfs:label "Prohibition Obligation"@en ;
    euaia:articleReference "Article 5"^^xsd:string ;
    rdfs:comment "Obligation not to place on market or use prohibited AI practices."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:Provider_Obligation a owl:Class ;
    rdfs:label "Provider Obligation"@en ;
    euaia:articleReference "Article 16"^^xsd:string ;
    rdfs:comment "Comply with provider duties for high-risk AI systems."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:Risk_Management_Obligation a owl:Class ;
    rdfs:label "Risk Management Obligation"@en ;
    euaia:articleReference "Article 9"^^xsd:string ;
    rdfs:comment "Maintain a continuous risk management system for high-risk AI."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:Transparency_Obligation a owl:Class ;
    rdfs:label "Transparency Obligation"@en ;
    euaia:articleReference "Articles 13, 50"^^xsd:string ;
    rdfs:comment "Inform users or affected persons when required under transparency rules."@en ;
    rdfs:subClassOf euaia:Obligation .

euaia:governed_by a owl:ObjectProperty ;
    rdfs:label "governed by"@en ;
    euaia:articleReference "Articles 64-71"^^xsd:string ;
    rdfs:comment "Actor is supervised by governance entities."@en ;
    rdfs:domain euaia:Actor ;
    rdfs:range euaia:Governance .

euaia:obligation_for a owl:ObjectProperty ;
    rdfs:label "obligation for"@en ;
    euaia:articleReference "Articles 5-56"^^xsd:string ;
    rdfs:comment "Inverse link from an obligation to covered actors or systems."@en ;
    rdfs:domain euaia:Obligation ;
    rdfs:range owl:Thing .

euaia:regulated_by a owl:ObjectProperty ;
    rdfs:label "regulated by"@en ;
    euaia:articleReference "Articles 57-71"^^xsd:string ;
    rdfs:comment "System is regulated by a governance entity."@en ;
    rdfs:domain euaia:AI_System ;
    rdfs:range euaia:Governance .

ex:chatbotService a euaia:Certain_AI_System ;
    rdfs:label "Public Service Chatbot"@en ;
    euaia:regulated_by ex:franceAuthority ;
    euaia:subject_to_obligation ex:obl_transparency_duty .

ex:euAIOffice a euaia:AI_Office ;
    rdfs:label "EU AI Office"@en ;
    euaia:regulates ex:foundationModelX .

ex:euDatabaseNode a euaia:EU_Database ;
    rdfs:label "EU High-Risk AI Database"@en ;
    euaia:regulates ex:creditScoringAISystem .

ex:obl_authority_cooperation a euaia:Authority_Cooperation_Obligation,
        euaia:Obligation ;
    rdfs:label "Authority Cooperation Duty"@en ;
    euaia:articleReference "Article 70"^^xsd:string ;
    euaia:obligation_for ex:franceAuthority ;
    rdfs:comment "National competent authorities cooperate and coordinate supervision."@en .

ex:obl_data_governance a euaia:Data_Governance_Obligation,
        euaia:Obligation ;
    rdfs:label "Data Governance Duty"@en ;
    euaia:articleReference "Article 10"^^xsd:string ;
    euaia:obligation_for ex:creditScoringAISystem ;
    rdfs:comment "High-risk AI systems must meet data governance and data quality requirements."@en .

ex:obl_deployer_compliance a euaia:Deployer_Obligation,
        euaia:Obligation ;
    rdfs:label "Deployer Compliance Duty"@en ;
    euaia:articleReference "Article 26"^^xsd:string ;
    euaia:obligation_for ex:cityEmploymentOffice ;
    rdfs:comment "Deployer must satisfy duties for operation of high-risk AI systems."@en .

ex:obl_fria a euaia:Fundamental_Rights_Impact_Assessment_Obligation,
        euaia:Obligation ;
    rdfs:label "Fundamental Rights Impact Assessment Duty"@en ;
    euaia:articleReference "Article 27"^^xsd:string ;
    euaia:obligation_for ex:cityEmploymentOffice ;
    rdfs:comment "Deployer must perform FRIA where required before use."@en .

ex:obl_gpai_provider a euaia:GPAI_Provider_Obligation,
        euaia:Obligation ;
    rdfs:label "GPAI Provider Duty"@en ;
    euaia:articleReference "Article 53"^^xsd:string ;
    euaia:obligation_for ex:foundationModelX ;
    rdfs:comment "Provider must satisfy baseline obligations for general-purpose AI models."@en .

ex:obl_gpai_systemic_risk a euaia:GPAI_Systemic_Risk_Obligation,
        euaia:Obligation ;
    rdfs:label "GPAI Systemic Risk Duty"@en ;
    euaia:articleReference "Article 55"^^xsd:string ;
    euaia:obligation_for ex:foundationModelX ;
    rdfs:comment "Additional duties apply to GPAI models classified with systemic risk."@en .

ex:obl_prohibition a euaia:Obligation,
        euaia:Prohibition_Obligation ;
    rdfs:label "Prohibition Duty"@en ;
    euaia:articleReference "Article 5"^^xsd:string ;
    euaia:obligation_for ex:socialScoringEngine ;
    rdfs:comment "Prohibited AI practices must not be placed on the market or used."@en .

ex:obl_provider_compliance a euaia:Obligation,
        euaia:Provider_Obligation ;
    rdfs:label "Provider Compliance Duty"@en ;
    euaia:articleReference "Article 16"^^xsd:string ;
    euaia:obligation_for ex:acmeProvider ;
    rdfs:comment "Provider must satisfy duties for high-risk AI systems."@en .

ex:obl_risk_management a euaia:Obligation,
        euaia:Risk_Management_Obligation ;
    rdfs:label "Risk Management Duty"@en ;
    euaia:articleReference "Article 9"^^xsd:string ;
    euaia:obligation_for ex:creditScoringAISystem ;
    rdfs:comment "High-risk AI systems must use continuous risk management processes."@en .

ex:regulatorySandboxFR a euaia:AI_Regulatory_Sandbox ;
    rdfs:label "French AI Sandbox"@en ;
    euaia:governs ex:acmeProvider .

ex:socialScoringEngine a euaia:Prohibited_AI_Practice ;
    rdfs:label "Social Scoring Engine"@en ;
    euaia:subject_to_obligation ex:obl_prohibition .

euaia:AI_Regulatory_Sandbox a owl:Class ;
    rdfs:label "AI Regulatory Sandbox"@en ;
    euaia:articleReference "Articles 57-58"^^xsd:string ;
    rdfs:comment "Controlled environment for testing innovative AI under supervision."@en ;
    rdfs:subClassOf euaia:Governance .

euaia:Deployer a owl:Class ;
    rdfs:label "Deployer"@en ;
    euaia:articleReference "Article 26"^^xsd:string ;
    rdfs:comment "Entity using an AI system under its authority."@en ;
    rdfs:subClassOf euaia:Actor .

euaia:Provider a owl:Class ;
    rdfs:label "Provider"@en ;
    euaia:articleReference "Articles 16, 53"^^xsd:string ;
    rdfs:comment "Entity that develops or places an AI system/model on the market."@en ;
    rdfs:subClassOf euaia:Actor .

ex:obl_transparency_duty a euaia:Obligation,
        euaia:Transparency_Obligation ;
    rdfs:label "Transparency Duty"@en ;
    euaia:articleReference "Articles 13, 50"^^xsd:string ;
    euaia:obligation_for ex:acmeProvider,
        ex:chatbotService ;
    rdfs:comment "Transparency obligations for certain AI systems and information duties."@en .

ex:acmeProvider a euaia:Provider ;
    rdfs:label "ACME AI Provider"@en ;
    euaia:participates_in_sandbox ex:regulatorySandboxFR ;
    euaia:provides ex:creditScoringAISystem,
        ex:foundationModelX ;
    euaia:subject_to_obligation ex:obl_provider_compliance,
        ex:obl_transparency_duty .

ex:cityEmploymentOffice a euaia:Deployer ;
    rdfs:label "City Employment Office"@en ;
    euaia:deploys ex:creditScoringAISystem ;
    euaia:governed_by ex:franceAuthority ;
    euaia:subject_to_obligation ex:obl_deployer_compliance,
        ex:obl_fria .

ex:foundationModelX a euaia:General_Purpose_AI_Model ;
    rdfs:label "Foundation Model X"@en ;
    euaia:regulated_by ex:euAIOffice ;
    euaia:subject_to_obligation ex:obl_gpai_provider,
        ex:obl_gpai_systemic_risk .

ex:franceAuthority a euaia:Authority,
        euaia:National_Competent_Authority ;
    rdfs:label "French AI Competent Authority"@en ;
    euaia:governs ex:cityEmploymentOffice ;
    euaia:subject_to_obligation ex:obl_authority_cooperation .

ex:creditScoringAISystem a euaia:High_Risk_AI_System ;
    rdfs:label "Credit Scoring AI System"@en ;
    euaia:regulated_by ex:euDatabaseNode ;
    euaia:subject_to_obligation ex:obl_data_governance,
        ex:obl_risk_management .

euaia:Actor a owl:Class ;
    rdfs:label "Actor"@en ;
    euaia:articleReference "Article 3"^^xsd:string ;
    rdfs:comment "Natural or legal persons and public bodies with duties under the Act."@en ;
    rdfs:subClassOf owl:Thing .

euaia:AI_System a owl:Class ;
    rdfs:label "AI System"@en ;
    euaia:articleReference "Article 3"^^xsd:string ;
    rdfs:comment "AI systems and AI models regulated under the Act."@en ;
    rdfs:subClassOf owl:Thing .

euaia:Governance a owl:Class ;
    rdfs:label "Governance"@en ;
    euaia:articleReference "Articles 57-71"^^xsd:string ;
    rdfs:comment "Institutional and procedural governance components of the Act."@en ;
    rdfs:subClassOf owl:Thing .

euaia:Obligation a owl:Class ;
    rdfs:label "Obligation"@en ;
    euaia:articleReference "Articles 5-56"^^xsd:string ;
    rdfs:comment "Normative requirements imposed by the EU AI Act."@en ;
    rdfs:subClassOf owl:Thing .

